# === AI Provider Configuration ===
# Your Google Gemini API key (required)
GEMINI_API_KEY=your_gemini_api_key

# Multiple Gemini models separated by commas — if one hits rate limit,
# the next one is tried automatically. Supported models:
# - gemini-2.0-flash
# - gemini-2.5-flash
# - gemini-2.5-flash-lite
# - gemini-3-flash
# - gemini-3.1-flash-lite
# - gemini-3.5-flash
GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-3.1-flash-lite,gemini-3-flash,gemini-2.5-flash-lite,gemini-3.5-flash

# --- OpenAI / OpenAI-Compatible (optional, for additional fallback) ---
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=  (optional, for compatible APIs like Ollama, Groq, etc.)

# --- Shared AI Settings ---
AI_MAX_OUTPUT_TOKENS=16384
AI_TEMPERATURE=0.1
AI_FALLBACK=true

# === Processing ===
BATCH_SIZE=10

# === Server ===
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:4000/api